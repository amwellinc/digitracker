# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── GoHighLevel OAuth (frontend — public values only) ─────────────────────────
# Client ID is public and safe to expose in the browser bundle.
VITE_GHL_CLIENT_ID=

# NEVER put GHL_CLIENT_SECRET here — it must only live as a Supabase secret:
#   supabase secrets set GHL_CLIENT_SECRET=your_secret
#   supabase secrets set GHL_WEBHOOK_SECRET=your_webhook_secret
#
# Supabase edge functions read these via Deno.env.get('GHL_CLIENT_SECRET').

# ── Stripe ────────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_STRIPE_BASIC_PRICE_ID=price_...
VITE_STRIPE_BUSINESS_PRICE_ID=price_...
VITE_STRIPE_PROFESSIONAL_PRICE_ID=price_...
